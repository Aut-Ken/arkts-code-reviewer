      "rule_type": "constraint",
      "text": "@Link 禁止本地初始化，其类型必须与数据源一致，且数据源必须是状态变量。",
      "heading_path": ["@Link装饰器：父子双向同步", "限制条件"],
      "dimension_ids": ["DIM-02", "DIM-05"],
      "review_question_ids": ["RQ-state"],
      "tags": ["has_state_management"],
      "decorators": ["@Link"],
      "domains": ["state-data-flow"],
      "raw_keywords": ["本地初始化"],
      "scenario": "@Link 初始化、类型与数据源约束",
      "conditional_only": false,
      "applicability_note": "API 23 起部分数据源错误由运行期前移到编译期，但约束本身不限于 API 23。",
      "risk_note": "应区分约束本身与不同 API level 的报错阶段。",
      "review_status": "proposed"
    },
    {
