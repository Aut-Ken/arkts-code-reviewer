      "source_span": {"start_line": 138, "end_line": 148},
      "source_span_sha256": "sha256:1cd7b1187165ba8a8fe92bc5380d9dc982ba8ec3bed2fe835c4a721e4a265aa2",
      "rule_type": "guidance",
      "text": "默认网络可能在 Wi-Fi、蜂窝或其他网络间切换，依赖默认网络的长连接应监控变化并迁移通信。",
      "heading_path": ["管理网络连接", "监控默认网络变化并主动重建网络连接"],
      "dimension_ids": ["DIM-05"],
      "review_question_ids": ["RQ-network"],
      "tags": ["has_network"],
      "apis": ["connection.createNetConnection", "connection.on('netAvailable')"],
      "domains": ["network-mobility"],
      "raw_keywords": ["默认网络"],
      "scenario": "默认网络切换后的长连接迁移",
      "conditional_only": true,
      "applicability_note": "适用于依赖默认网络且需要持续通信的长连接。",
      "risk_note": "一次性 HTTP 请求或显式绑定指定网络的连接不应无条件套用。",
      "review_status": "proposed"
    },
    {
      "rule_id": "OHDOC-E2E/STATE-01",
      "target_tag": "has_state_management",
      "document_alias": "doc017",
      "source_span": {"start_line": 31, "end_line": 31},
      "source_span_sha256": "sha256:4c43d04144dfd3b85dab5327c0dd44e44b5b80bafbb694a4e46befc779517d58",
      "rule_type": "constraint",
      "text": "ArkUI 状态管理只能在 UI 主线程使用，不能在子线程、Worker 或 TaskPool 中使用。",
      "heading_path": ["状态管理概述"],
      "dimension_ids": ["DIM-02", "DIM-05"],
      "review_question_ids": ["RQ-state"],
      "tags": ["has_state_management"],
      "domains": ["state-management"],
      "raw_keywords": ["UI主线程"],
      "scenario": "ArkUI 状态管理的线程边界",
      "conditional_only": false,
      "applicability_note": "只约束 ArkUI 状态管理能力，不约束普通类字段或 Sendable 数据。",
      "risk_note": "必须先证明对象使用 ArkUI 状态管理，不能把所有跨线程数据都归入本条。",
      "review_status": "proposed"
    },
    {
      "rule_id": "OHDOC-E2E/STATE-02",
      "target_tag": "has_state_management",
      "document_alias": "doc018",
      "source_span": {"start_line": 117, "end_line": 125},
      "source_span_sha256": "sha256:ccad9896190806105f13e2cfaec3e15eb53db7c9119dea610619999a9f9f57a6",
      "rule_type": "behavior",
      "text": "V1 @State 无法观察嵌套对象属性或数组项内部属性的直接修改，因此此类修改不会触发 UI 刷新。",
      "heading_path": ["@State装饰器：组件内状态", "观察变化和行为表现", "观察变化"],
      "dimension_ids": ["DIM-02", "DIM-05"],
      "review_question_ids": ["RQ-state"],
      "tags": ["has_state_management"],
      "decorators": ["@State"],
      "domains": ["state-observation"],
      "raw_keywords": ["嵌套属性"],
      "scenario": "V1 @State 对嵌套对象和数组项属性的观察深度",
      "conditional_only": true,
      "applicability_note": "仅适用于 V1 @State 的深层直接修改；整体重新赋值和 V2 深度观察需另行判断。",
      "risk_note": "不能把整体赋值、数组受支持操作或 V2 @Trace 语义误判为不可观察。",
      "review_status": "proposed"
    },
    {
      "rule_id": "OHDOC-E2E/STATE-03",
      "target_tag": "has_state_management",
      "document_alias": "doc016",
      "source_span": {"start_line": 21, "end_line": 25},
      "source_span_sha256": "sha256:529b2b373dd9f40b9cb6cabef24de890830d458fa74b8f966dd0f0056bc2f52d",
      "rule_type": "behavior",
      "text": "@Prop 的本地修改不会同步回父组件，父数据源更新时会覆盖子组件中的本地修改。",
      "heading_path": ["@Prop装饰器：父子单向同步", "概述"],
      "dimension_ids": ["DIM-02", "DIM-05"],
      "review_question_ids": ["RQ-state"],
      "tags": ["has_state_management"],
      "decorators": ["@Prop"],
      "domains": ["state-data-flow"],
      "raw_keywords": ["单向同步"],
      "scenario": "@Prop 的父子单向同步和本地修改覆盖",
      "conditional_only": true,
      "applicability_note": "适用于 @Prop 与父数据源之间的单向同步关系。",
      "risk_note": "本地临时修改可能是有意设计，必须结合预期数据流判断。",
      "review_status": "proposed"
    },
    {
      "rule_id": "OHDOC-E2E/STATE-04",
      "target_tag": "has_state_management",
      "document_alias": "doc016",
      "source_span": {"start_line": 36, "end_line": 36},
      "source_span_sha256": "sha256:aacdef8de6d32aa3768426d6f6e03fed2a23bc27aa52382839fdaecf81f872d0",
      "rule_type": "guidance",
      "text": "组件复用场景中不建议让 @Prop 深层嵌套超过五层；深拷贝可能增加内存和 GC 开销，可考虑 @ObjectLink。",
      "heading_path": ["@Prop装饰器：父子单向同步", "装饰器使用规则说明"],
      "dimension_ids": ["DIM-03"],
      "review_question_ids": ["RQ-state"],
      "tags": ["has_state_management"],
      "decorators": ["@ObjectLink", "@Prop"],
      "domains": ["state-performance"],
      "raw_keywords": ["深拷贝"],
      "scenario": "@Prop 深层嵌套的复制与回收成本",
      "conditional_only": true,
      "applicability_note": "只适用于组件复用和深层数据传递场景。",
      "risk_note": "五层是性能建议而非无条件编译规则，不能仅凭层数直接报确定性缺陷。",
      "review_status": "proposed"
    },
    {
      "rule_id": "OHDOC-E2E/STATE-05",
      "target_tag": "has_state_management",
      "document_alias": "doc012",
      "source_span": {"start_line": 81, "end_line": 81},
