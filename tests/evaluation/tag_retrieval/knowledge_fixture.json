      "rule_type": "guidance",
      "text": "不建议在 @Entry 页面根组件中使用 @Link，否则可能出现编译警告或运行时错误。",
      "heading_path": ["@Link装饰器：父子双向同步", "限制条件"],
      "dimension_ids": ["DIM-02", "DIM-05"],
      "review_question_ids": ["RQ-state"],
      "tags": ["has_state_management"],
      "decorators": ["@Entry", "@Link"],
      "domains": ["state-data-flow"],
      "raw_keywords": ["页面根节点"],
      "scenario": "@Entry 页面根组件中的 @Link 使用",
      "conditional_only": true,
      "applicability_note": "必须同时确认组件被 @Entry 装饰并作为页面根节点使用。",
      "risk_note": "普通子组件中的 @Link 不适用本条。",
      "review_status": "proposed"
    },
    {
      "rule_id": "OHDOC-E2E/STATE-06",
      "target_tag": "has_state_management",
      "document_alias": "doc012",
      "source_span": {"start_line": 83, "end_line": 97},
