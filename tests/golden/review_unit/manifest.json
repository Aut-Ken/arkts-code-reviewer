{
  "schema_version": "review-unit-golden-v1",
  "suite_id": "review-unit-golden-v1",
  "description": "Human-reviewed ReviewUnit selection and identity truth, independent of Parser Golden.",
  "coordinate_system": {
    "line_base": 1,
    "line_end": "inclusive",
    "columns": "unsupported"
  },
  "frozen_contract": {
    "unit_kinds": [
      "struct",
      "class",
      "function",
      "method",
      "build_method",
      "builder",
      "ui_block",
      "fallback"
    ],
    "selection_reasons": [
      "full_top_level_declaration",
      "innermost_changed_declaration",
      "large_build_ui_block",
      "fallback_window"
    ],
    "diagnostic_codes": [
      "budget_not_enforced",
      "changed_lines_outside_context",
      "diff_file_without_hunks",
      "hunk_out_of_range",
      "no_matching_declaration",
      "parser_degraded",
      "parser_error_nodes",
      "parser_missing_nodes",
      "unsupported_deletion_only"
    ]
  },
